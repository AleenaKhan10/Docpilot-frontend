# Production env template for Vercel.
# These get set in the Vercel dashboard:
#   Project Settings → Environment Variables
#
# Note: only VITE_* prefixed vars are exposed to the browser bundle.

# Supabase project (same project the backend talks to)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# DocPilot backend — point at the VPS, not localhost
VITE_API_BASE_URL=https://api.yourdomain.com
VITE_WS_BASE_URL=wss://api.yourdomain.com
